# .env.example

# ── Jira / Atlassian ──────────────────────────────────────────────
JIRA_BASE_URL=https://seculayer.atlassian.net
JIRA_EMAIL=your-email@seculayer.com
JIRA_API_TOKEN=your-jira-api-token

# ── Gemini AI ────────────────────────────────────────────────────
AI_ENABLED=true
GEMINI_API_KEY=your-gemini-api-key

# ── PostgreSQL ──────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_NAME=auto_reports

# ── 스케줄러 ────────────────────────────────────────────────────
SCHEDULE_CRON=0 23 * * 5
TZ=Asia/Seoul

# ── 앱 포트 (IP 접속 시 사용) ────────────────────────────────────
APP_PORT=80

# ── SSL / 도메인 (DNS 등록 후 사용) ────────────────────────────
DOMAIN=your-domain.com
SSL_EMAIL=your@email.com

# ── Confluence (선택) ──────────────────────────────────────────────
CONFLUENCE_SPACE_KEY=ieWRHnTeNNMB
CONFLUENCE_PARENT_PAGE_ID=
