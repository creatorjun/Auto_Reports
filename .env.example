# .env.example — 복사 후 .env 로 저장하여 실제 값 입력

# ── Jira / Atlassian ──────────────────────────────────
JIRA_BASE_URL=https://seculayer.atlassian.net
JIRA_EMAIL=your-email@seculayer.com
JIRA_API_TOKEN=your-jira-api-token

# ── Gemini AI ─────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── PostgreSQL ────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_NAME=auto_reports

# ── 스케줄러 ──────────────────────────────────────────
# 크론 표현식 (기본: 매주 금요일 23:00)
SCHEDULE_CRON=0 23 * * 5
TZ=Asia/Seoul

# ── 앱 포트 ───────────────────────────────────────────
APP_PORT=80

# ── Confluence (선택) ─────────────────────────────────
CONFLUENCE_SPACE_KEY=ieWRHnTeNNMB
CONFLUENCE_PARENT_PAGE_ID=
